#lang racket 
(require 2htdp/image)
(require 2htdp/universe)
(require test-engine/racket-tests)
(require "go_draw_board.rkt")


;;Zustände:
;; 1. w=(wait   )      - Abwarten
;; 2. w=(play   )      - An der Reihe
;; 3. w=(won    )      - Gewonnen
;; 4. w=(lost   )      - Verloren
;; 4. w=(remis  )      - Unentschieden

;;Startzustand
(define WORLD0 (list 'wait (make-list 19 (make-list 19 0))))

;;Falls ein korrekter Weltzustand empfangen wird
;;   --> setze die Welt auf die empfangene Nachricht
;;sonst: verharre im alten Weltzustand
(define (receive w m)
  (if (and (list? m) (= (length m) 2)
           (symbol? (first m)) 
           (list? (second m)) (= (length (second m)) 9))
      m
      w))



;;Zeichnen einer Welt
;;Hilfsfunktionen

(define new_game_text (above(text "Für ein neues Spiel" 16 'black)
                            (text "bitte klicken" 16 'black)))

;;Eigentliches Zeichen
(define (draw name)
    (lambda (w)
      (cond ;;Won
             [(equal? (car w) 'won)
              (above
               (text "Gewonnen" 22 'darkgreen)
               new_game_text)]
             ;;Lost
             [(equal? (car w) 'lost)
              (above 
               (text "Verloren" 22 'red)
                new_game_text)]
             ;;Remis
             [(equal? (car w) 'remis)
              (above 
               (text "Remis" 22 'blue) 
               new_game_text)]
             ;;Sonst wird normal gespielt
             [else
                (above
                 (draw-board-with-score (second w))
                 (if (equal? (car w) 'wait)
                     (text "warte auf Gegner..." 16 'red)
                     (text "bitte Zelle markieren!" 16 'darkgreen)))
                 ])))
;;Maus-Interaktionen
(define (handle-mouse name)
  (lambda (w x_pos y_pos mouse_event)
    (if(mouse=? mouse_event "button-up")
       (if (or (equal? (car w) 'won)
               (equal? (car w) 'lost)
               (equal? (car w) 'remis))
           (make-package w 'restart)
           (let* ((column (quotient x_pos 50))
                  (row    (quotient y_pos 50))
                  (index  (+ (* 3 row) column)))
             (if (< -1 index 9) 
                 (make-package w (list 'set index))
                 w)))
       w)))

;;Erstelle eine Welt und verbinde sie mit dem LOCALHOST Server
(define (create-world n)
    (big-bang WORLD0
             (on-receive receive)
             (to-draw (draw n))
             (on-mouse (handle-mouse n))
             (name n)
             (state #t)
             (register LOCALHOST)))

;;Macht zwei Welten auf
(launch-many-worlds 
  (create-world "X")
  (create-world "O")
  (create-world "B"))